{
  "name": "auralmusic",
  "version": "1.0.0",
  "type": "module",
  "description": "Aural Music Player",
  "author": "AuralMusic Team <noreply@auralmusic.app>",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite",
    "dev:web": "vite",
    "build": "tsc -b && electron-vite build",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "commit": "cz",
    "release": "release-it",
    "release:gh": "node scripts/release-with-gh-token.mjs",
    "check": "pnpm lint && pnpm build",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.3.2",
