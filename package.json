    "@neteasecloudmusicapienhanced/api": "^4.31.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "axios": "^1.14.0",
    "card": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "electron-store": "^11.0.2",
    "embla-carousel-react": "^8.6.0",
    "font-list": "^2.0.2",
    "form-data": "^4.0.5",
    "jss": "^10.10.0",
    "jss-preset-default": "^10.10.0",
    "keepalive-for-react": "^5.0.8",
    "keepalive-for-react-router": "^5.0.7",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "node-id3": "^0.2.9",
    "plyr": "^3.8.4",
    "plyr-react": "^6.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.1.0",
