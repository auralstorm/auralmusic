{
  "git": {
    "commitMessage": "chore: release v${version}",
    "pushRepo": "https://example.com/auralmusic.git",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": false,
    "requireUpstream": false,
    "push": false
  },
  "github": {
    "release": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "preset": "conventionalcommits"
    }
  }
}
